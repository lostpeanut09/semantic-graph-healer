{
    "$schema": "https://unpkg.com/knip@5/schema.json",
    "project": ["**/*.ts"],
    "ignore": [],
    "ignoreDependencies": ["@vitest/ui", "vitest", "@typescript-eslint/eslint-plugin", "@typescript-eslint/parser"],
    "rules": {
