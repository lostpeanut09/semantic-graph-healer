{
    "name": "semantic-graph-healer",
    "version": "1.3.0",
    "type": "module",
    "description": "Topological restoration engine that utilizes Dataview, Breadcrumbs, and ExcaliBrain metadata to identify and resolve structural inconsistencies in the knowledge graph.",
    "main": "main.js",
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
        "lint": "eslint .",
        "lint:css": "stylelint \"**/*.css\"",
        "format": "prettier --write .",
        "knip": "knip",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{js,ts}": "eslint --fix",
        "*.css": "stylelint --fix",
        "**/*": "prettier --write --ignore-unknown"
    },
    "keywords": [],
    "author": "lostpeanut09",
    "license": "GPL-3.0",
    "devDependencies": {
        "@eslint/json": "^0.14.0",
        "@types/node": "^24.0.0",
        "@typescript-eslint/eslint-plugin": "^8.57.2",
        "@typescript-eslint/parser": "^8.57.2",
        "@vitest/ui": "^4.1.0",
        "builtin-modules": "^3.3.0",
        "esbuild": "^0.20.0",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-obsidianmd": "^0.1.9",
        "husky": "^9.1.7",
        "knip": "^6.0.5",
        "lint-staged": "^16.4.0",
        "obsidian": "latest",
        "obsidian-typings": "^5.18.0",
        "prettier": "^3.8.1",
        "stylelint": "^17.5.0",
        "stylelint-config-standard": "^40.0.0",
        "tslib": "^2.4.0",
        "typescript": "^5.0.0",
        "typescript-eslint": "^8.57.2",
        "vitest": "^4.1.0"
    },
    "dependencies": {
        "graphology": "^0.26.0",
        "graphology-communities-louvain": "^2.0.2",
        "graphology-metrics": "^2.4.0",
        "graphology-types": "^0.24.8",
        "zod": "^4.3.6"
    }
}
