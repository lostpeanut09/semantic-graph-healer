{
    "$schema": "https://unpkg.com/knip@5/schema.json",
    "project": ["**/*.ts"],
    "entry": ["src/main.ts", "src/core/workers/graph-analysis-worker.ts", ".config/esbuild.config.mjs"],
    "ignore": [],
    "ignoreDependencies": [
        "stylelint-config-standard",
        "@typescript-eslint/eslint-plugin",
        "@typescript-eslint/parser"
    ],
    "rules": {
        "files": "error",
        "dependencies": "error",
        "unlisted": "error",
        "exports": "error",
        "types": "error"
    }
}
